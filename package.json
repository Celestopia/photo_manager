{
  "name": "photo-manager",
  "version": "0.1.0",
  "description": "Local image and video manager built with Electron and Vue",
  "main": "src/main/main.js",
  "scripts": {
    "start": "npm run build:renderer && node scripts/start-electron.js",
    "build:renderer": "vite build --config vite.config.mjs",
    "build-thumbnails": "node scripts/build-thumbnails.js",
    "init-metadata": "node scripts/init-metadata.js",
    "update-metadata": "node scripts/update-metadata.js",
    "verify-metadata": "node scripts/verify-metadata.js",
    "export-metadata-csv": "node scripts/export-metadata-csv.js",
    "test": "node --test tests"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.2.1",
    "vite": "^5.4.11"
  },
  "dependencies": {
    "electron": "^35.0.0",
    "exifr": "^7.1.3",
    "js-yaml": "^4.1.0",
    "sharp": "^0.34.2",
    "vue": "^3.5.13"
  }
}
