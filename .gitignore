photo_metadata.jsonl
photo_metadata.csv
tag_registry.jsonl
album_registry.jsonl
person_registry.jsonl
location_registry.jsonl

# Temporary files
*.tmp
*.temp
*.bak

# Build / packaging outputs
dist/
out/
release/

# IDE / editor
.vscode/
.idea/
*.swp
*.swo

# OS files
.DS_Store
Thumbs.db
Desktop.ini
